 import qrcode
import os

def generate_qr(student_name, class_name):
    data = f"{student_name}|{class_name}"
    qr = qrcode.make(data)
    dir_path = f"qrcodes/{class_name}"
    os.makedirs(dir_path, exist_ok=True)
    qr.save(f"{dir_path}/{student_name}.png")

def main():
    file_name = input("📁 Enter(LIKE-class1.txt): ").strip()
    file_path = f"student_lists/{file_name}"


    class_name = os.path.splitext(file_name)[0] 

    with open(file_path) as f:
        students = [line.strip() for line in f.readlines()]
    
    for student in students:
        generate_qr(student, class_name)
    
    print(f"✅ QR Codes generated for {class_name} in 'qrcodes/{class_name}' folder.")

if __name__ == "__main__":
    main()
